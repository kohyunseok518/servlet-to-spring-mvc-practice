<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

<!--    서블릿 등록-->
    <servlet>
        <servlet-name>MemberFormServlet</servlet-name>
        <servlet-class>com.org.servlet.MemberFormServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>MemberServlet</servlet-name>
        <servlet-class>com.org.servlet.MemberServlet</servlet-class>
    </servlet>
    
<!--    URL와 서블릿 매핑-->
<!--    web.xml은 GET, POST만 보고 Servlet을 나누지 않고 URL만 보고 Servlet을 나눈다.-->
    <servlet-mapping>
        <servlet-name>MemberFormServlet</servlet-name>
        <url-pattern>/members/new</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>MemberServlet</servlet-name>
        <url-pattern>/members</url-pattern>
    </servlet-mapping>
</web-app>

